# deps
# Node.js dependencies
node_modules
.pnpm-store
.pnpm-debug.log
.pnpm/

# Keep pnpm-lock.yaml
!pnpm-lock.yaml

# build
dist/
bazel-*
user.bazelrc
build/
out/
storybook-static/

# ignore Nix derivation results
result

# editor
.vscode/
.idea/
.history/
.zed/
*.swp
*.swo
*~
*.code-workspace

# Local AI/LLM runtime state
#
# Every Code writes sensitive local state under .code/: prompts, agent output,
# Code Bridge subscriptions, Chronicle artifacts, logs, and work caches.
# Keep only the nested guard file trackable.
!/.code/
/.code/*
!/.code/.gitignore

# Keep repo-level .codex config and skills visible, but ignore local runtime
# leaves generated by agent sessions.
/.codex/sessions/
/.codex/history*.jsonl
/.codex/log/
/.codex/logs/
/.codex/tmp/
/.agents/runs/
/.agents/tmp/
/.agents/cache/

# Antigravity stores local runtime/session state here.
/.antigravitycli/

# Claude project config may be intentional. Keep .claude/settings.json,
# .claude/agents/, and .claude/commands/ visible; ignore local overrides.
/.claude/settings.local.json
/.claude/settings.local.*.json

# Aider local history/cache. Keep .aider.conf.yml and .aiderignore visible.
/.aider.chat.history.md
/.aider.input.history
/.aider.llm.history
/.aider.tags.cache.*/

# Binary symlinks generated by dev-fast builds
code-rs/code-cli/bin/
codex-rs/codex-cli/bin/
code-rs/bin/

# Rust build artifacts
/target/
/codex-rs/target/
**/*.rs.bk

# Local Cargo caches (never commit)
# Keep anchored rules for root, and add unanchored patterns so nested workspaces
# like codex-rs/.cargo-home are also ignored.
/.cargo-home/
/.cargo-cache/
/.cargo2/
.cargo-home/
.cargo2/
/codex-rs/.cargo-home/
/codex-rs/.cargo2/

# Release and CI scratch
/.code-bin/
/artifacts/
/release-assets/
/npm-binaries/
/.github/auto/

# Legacy Homebrew formula staging scratch
Formula/Code.rb
homebrew-tap/Formula/Code.rb

# Local GitHub Actions runners and caches
.act/
actions-runner/
.github/workflows/*-local.yml
.github/workflows/.cache/

# caches
/cache/
.cache/
__pycache__/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.turbo/
.parcel-cache/
.eslintcache
.nyc_output/
.jest/
*.tsbuildinfo
playwright-report/

# temp files
.tmp/
tmp/
temp/
.merge-backup
.target-test/
.target-test-pre/

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env
.env*
!.env.example
.venv/

# package
*.tgz

# ci
.vercel/
.netlify/

# patches
apply_patch/

# generated reports
reports/

# coverage
coverage/

# personal files
personal/
scratch/
handoff*.md

# os
.DS_Store
Thumbs.db
Icon?
.Spotlight-V100/

# Unwanted package managers
.yarn/
yarn.lock

# release
package.json-e
session.ts-e
CHANGELOG.ignore.md

# nix related
.direnv
.envrc

# git worktrees
branches/
/.wt-*/
.worktrees/

# coder directories
.coder/
*.override.*

# trigger: test non-notes change (no [skip ci])

# release notes (generated by CI)
docs/release-notes/prompt.expanded.txt
docs/release-notes/context.md
prompts/projects/
